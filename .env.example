# === API (apps/api/.env) ===
NODE_ENV=development
PORT=3001

# Neon PostgreSQL — https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dogapp?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.neon.tech/dogapp?sslmode=require

# Upstash Redis — https://console.upstash.com
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# JWT (generate: openssl rand -base64 32)
JWT_SECRET=change-me-min-32-chars-random-string-here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Cloudflare R2
R2_ACCOUNT_ID=xxx
R2_ACCESS_KEY_ID=xxx
R2_SECRET_ACCESS_KEY=xxx
R2_BUCKET_NAME=dogapp-dev
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# Resend (email)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@dogapp.io

# Expo push
EXPO_ACCESS_TOKEN=xxx

# Google Places (F10)
GOOGLE_PLACES_API_KEY=xxx

# === MOBILE (apps/mobile/.env.local) ===
EXPO_PUBLIC_API_URL=http://localhost:3001/api/v1

# === WEB (apps/web/.env.local) ===
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
